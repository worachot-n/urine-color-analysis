# Copy this file to .env and fill in the values before running.
# The .env file must NOT be committed to git.

# Shared secret — must match on both Pi and server
API_KEY=change-me-to-a-long-random-secret

# Pi client only: full HTTPS URL of the analysis server
# Examples:
#   Local:      http://192.168.1.100:8000
#   Cloudflare: https://your-tunnel.trycloudflare.com
SERVER_URL=https://your-domain.trycloudflare.com

# Telegram notifications (server-side, optional)
# Leave blank to disable.  Get a token from @BotFather.
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/urine_db
